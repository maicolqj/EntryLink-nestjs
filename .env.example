# =============================================================================
# ENTRYLINK - CONFIGURACIÓN DE VARIABLES DE ENTORNO
# =============================================================================
# Fecha de creación: 2026-02-14
# Autor: DevOps Team
# Descripción: Variables de entorno organizadas por categorías para el proyecto ENTRYLINK
# =============================================================================

# =============================================================================
# 1. CONFIGURACIÓN GENERAL DE LA APLICACIÓN
# =============================================================================
NODE_ENV=
APPNAME=
PORT=
TZ=
ALLOWED_ORIGINS=
BCRYPT_ROUNDS=
FINGERPRINT_SECRET=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ISSUER=

# =============================================================================
# 2. CONFIGURACIÓN DE BASE DE DATOS POSTGRESQL
# =============================================================================
DB_HOST=
DB_PORT_LOCAL=
DB_PORT_DOCKER=
DB_USERNAME=
DB_NAME=
PASSDB_POSTGRES=

# Configuración del contenedor
CONTAINER_NAME_DB=

# Configuración de zona horaria y rendimiento
POSTGRES_TIMEZONE=
POSTGRES_MAX_CONNECTIONS=
POSTGRES_SHARED_BUFFERS=
POSTGRES_EFFECTIVE_CACHE_SIZE=

# Configuración adicional de PostgreSQL
POSTGRES_MAINTENANCE_WORK_MEM=
POSTGRES_CHECKPOINT_COMPLETION_TARGET=
POSTGRES_WAL_BUFFERS=
POSTGRES_WORK_MEM=
POSTGRES_MIN_WAL_SIZE=
POSTGRES_MAX_WAL_SIZE=
DB_SSL=
# =============================================================================
# 3. CONFIGURACIÓN DE REDIS Y CACHE
# =============================================================================
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_REPLICA_PORT=
REDIS_QUEUE_DB=
REDIS_PREFIX=
# Configuración de cache
CACHE_TTL=
DEFAULT_PREFIX=
LOCK_TIME_MINUTES=
MAX_FAILED_ATTEMPTS=
REDIS_DB=
REDIS_SOCKET_DB=

# =============================================================================
# 4. CONFIGURACIÓN DE COLAS Y TRABAJOS (BULL/BULLMQ)
# =============================================================================
BULL_ATTEMPTS=
BULL_REMOVE_ON_COMPLETE=
BULL_REMOVE_ON_FAIL=
BULL_BOARD_USER=
BULL_BOARD_PASS=

# =============================================================================
# 5. CONFIGURACIÓN DE R2 CLOUFLARE (almacenamiento de imágenes y documentos)
# =============================================================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=


# =============================================================================
# 6. CONFIGURACIÓN DE SERVICIOS DE COMUNICACIÓN
# =============================================================================

# Configuración de Mail
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=

FRONTEND_URL=

# WhatsApp Cloud API (Meta) — envío de códigos de acceso/OTP
# Si se dejan vacías, el envío queda deshabilitado (en dev el código sale en logs)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=
WHATSAPP_OTP_TEMPLATE_NAME=
WHATSAPP_CODE_TEMPLATE_NAME=
# Debe coincidir EXACTO con el idioma de la plantilla aprobada en Meta
# (ej. es_CO para "Español (Colombia)", no solo "es").
WHATSAPP_TEMPLATE_LANG=
# WABA ID (WhatsApp Business Account) — solo para gestionar plantillas con
# `yarn whatsapp:templates`. Es distinto del PHONE_NUMBER_ID usado para enviar.
WHATSAPP_BUSINESS_ACCOUNT_ID=


# =============================================================================
# 7. CONFIGURACIÓN DE DOCKER Y NETWORKING
# =============================================================================

CONTAINER_NAME_REDIS=
CONTAINER_NAME_APP=
CONTAINER_NAME_BULL_BOARD=


# =============================================================================
# 8. CONFIGURACIÓN DE PUSH NOTIFICATIONS
# =============================================================================
# Firebase Admin (FCM)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
  # Web Push VAPID
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# =============================================================================
# 9. CONFIGURACIÓN DEL SEED (solo se usa al correr el seed, nunca en runtime)
# =============================================================================
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=*
SEED_ADMIN_PHONE=
SEED_ADMIN_IDENTITY=